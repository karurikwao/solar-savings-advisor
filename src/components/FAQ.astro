---
import FAQSchema from "@/components/seo/FAQSchema.astro";
import type { FAQItem } from "@/lib/types";

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section class="my-12">
    <FAQSchema items={items} />
    <h2 class="mb-6 text-2xl font-black text-deep-navy">Frequently Asked Questions</h2>
    <div class="space-y-3">
      {items.map((item, index) => (
        <details class="surface-card p-0" open={index === 0}>
          <summary class="cursor-pointer px-6 py-4 font-bold text-deep-navy">{item.question}</summary>
          <div class="border-t border-gray-100 px-6 py-4 text-sm leading-relaxed text-gray-600">{item.answer}</div>
        </details>
      ))}
    </div>
  </section>
)}
