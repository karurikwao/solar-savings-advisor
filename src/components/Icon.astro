---
interface Props {
  name?: string;
  class?: string;
}

const { name = "sun", class: className = "h-5 w-5" } = Astro.props;
const paths: Record<string, string[]> = {
  sun: ["M12 3v2", "M12 19v2", "M5.6 5.6l1.4 1.4", "M17 17l1.4 1.4", "M3 12h2", "M19 12h2", "M5.6 18.4l1.4-1.4", "M17 7l1.4-1.4"],
  zap: ["M13 2L4 14h7l-1 8 9-12h-7l1-8z"],
  battery: ["M3 7h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H3z", "M21 11v2"],
  card: ["M3 6h18v12H3z", "M3 10h18"],
  chart: ["M4 19V5", "M4 19h16", "M8 15l3-4 3 2 4-7"],
  shield: ["M12 3l7 3v5c0 5-3.5 8-7 10-3.5-2-7-5-7-10V6l7-3z"],
  map: ["M9 18l-6 3V6l6-3 6 3 6-3v15l-6 3-6-3z", "M9 3v15", "M15 6v15"],
  help: ["M12 17h.01", "M9.5 9a2.5 2.5 0 1 1 4 2c-.9.6-1.5 1.2-1.5 2.5"],
  scale: ["M12 3v18", "M5 7h14", "M6 7l-3 7h6L6 7z", "M18 7l-3 7h6l-3-7z"],
  phone: ["M22 16.9v3a2 2 0 0 1-2.2 2A19.8 19.8 0 0 1 3.1 5.2 2 2 0 0 1 5.1 3h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L9 10.6a16 16 0 0 0 5.4 5.4l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z"],
  check: ["M5 12l4 4L19 6"],
  x: ["M6 6l12 12", "M18 6L6 18"]
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === "sun" && <circle cx="12" cy="12" r="4" />}
  {(paths[name] ?? paths.sun).map((d) => <path d={d} />)}
</svg>
