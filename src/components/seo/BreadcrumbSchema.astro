---
import JsonLd from "@/components/seo/JsonLd.astro";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
const allItems = [{ label: "Home", href: "/" }, ...items];
const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: allItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.label,
    item: item.href ? new URL(item.href, Astro.site ?? Astro.url.origin).toString() : Astro.url.toString(),
  })),
};
---

<JsonLd data={schema} />
