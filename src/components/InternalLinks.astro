---
import CTAButton from "@/components/CTAButton.astro";
import { comparisons, guides, questions, siteSettings } from "@/lib/content";
import { getToolPath, tools } from "@/lib/tools";

interface Props {
  currentId?: string;
  currentType?: "tool" | "question" | "comparison" | "guide" | "provider";
}

const { currentId = "", currentType = "question" } = Astro.props;
const toolLinks = tools.filter((tool) => tool.id !== currentId).slice(0, 3);
const questionLinks = questions.filter((item) => item.id !== currentId).slice(0, 3);
const comparisonLinks = comparisons.filter((item) => item.id !== currentId).slice(0, 3);
const guideLinks = guides.filter((item) => item.id !== currentId).slice(0, 3);
const reportPath = siteSettings.routes?.reportPath ?? "/solar-report/";
---

<section class="my-10 rounded-2xl border border-gray-200 bg-white p-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-black uppercase tracking-wider text-bright-orange">Related resources</p>
      <h2 class="mt-2 text-2xl font-black text-deep-navy">Keep comparing before you commit</h2>
    </div>
    <CTAButton href={reportPath} label="Get My Solar Report" variant="navy" placementId="bottom-lead" />
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-4">
    <div>
      <h3 class="font-black text-deep-navy">Tools</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {toolLinks.map((tool) => <li><a class="text-gray-700 hover:text-bright-orange" href={`/tools/${getToolPath(tool)}/`}>{tool.title}</a></li>)}
      </ul>
    </div>
    <div>
      <h3 class="font-black text-deep-navy">Questions</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {questionLinks.map((item) => <li><a class="text-gray-700 hover:text-bright-orange" href={`/questions/${item.path}/`}>{item.title}</a></li>)}
      </ul>
    </div>
    <div>
      <h3 class="font-black text-deep-navy">Comparisons</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {comparisonLinks.map((item) => <li><a class="text-gray-700 hover:text-bright-orange" href={`/compare/${item.path}/`}>{item.title}</a></li>)}
      </ul>
    </div>
    <div>
      <h3 class="font-black text-deep-navy">Guides</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {guideLinks.map((item) => <li><a class="text-gray-700 hover:text-bright-orange" href={`/guides/${item.path}/`}>{item.title}</a></li>)}
      </ul>
    </div>
  </div>
</section>
