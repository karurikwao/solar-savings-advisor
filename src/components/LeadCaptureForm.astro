---
import DisclosureNote from "@/components/DisclosureNote.astro";
import { disclosureSettings, siteSettings } from "@/lib/content";
import { normalizePageSlug } from "@/lib/tracking";

interface Props {
  title?: string;
  subtitle?: string;
  placementId?: string;
  pageSlug?: string;
  endpoint?: string;
}

const {
  title = "Request Quote Prep",
  subtitle = "Send basic contact details for organized solar quote follow-up.",
  placementId = "bottom-lead",
  pageSlug = normalizePageSlug(Astro.url.pathname),
  endpoint = siteSettings.leadCapture?.defaultEndpoint || "/api/submissions",
} = Astro.props;
const sourceId = siteSettings.siteId ?? "advisor-site";
const nicheName = siteSettings.nicheName ?? "Advisor";
const providerLabel = siteSettings.routes?.providerLabel ?? "Providers";
---

<section class="surface-card p-6" data-lead-form data-endpoint={endpoint}>
  <p class="text-xs font-black uppercase tracking-wider text-bright-orange">Quote follow-up</p>
  <h2 class="mt-2 text-2xl font-black text-deep-navy">{title}</h2>
  <p class="mt-2 text-sm leading-relaxed text-gray-600">{subtitle}</p>

  <form class="mt-6 grid gap-4" data-lead-form-fields>
    <input type="hidden" name="placementId" value={placementId} />
    <input type="hidden" name="pageSlug" value={pageSlug} />
    <input type="hidden" name="source" value={sourceId} />

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="text-sm font-bold text-deep-navy">
        Name
        <input name="name" class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" autocomplete="name" placeholder="Jane Smith" />
      </label>
      <label class="text-sm font-bold text-deep-navy">
        Email
        <input name="email" type="email" class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" autocomplete="email" placeholder="jane@example.com" />
      </label>
      <label class="text-sm font-bold text-deep-navy">
        Phone
        <input name="phone" type="tel" class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" autocomplete="tel" placeholder="(555) 555-5555" />
      </label>
      <label class="text-sm font-bold text-deep-navy">
        ZIP Code
        <input name="zip" class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" autocomplete="postal-code" inputmode="numeric" placeholder="90210" />
      </label>
    </div>

    <label class="text-sm font-bold text-deep-navy">
      Interest
      <select name="interest" class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3">
        <option value="primary">{nicheName} options</option>
        <option value="provider-comparison">{providerLabel} comparison</option>
        <option value="pricing">Pricing or savings estimate</option>
        <option value="implementation">Implementation questions</option>
      </select>
    </label>

    <label class="flex items-start gap-3 text-sm leading-relaxed text-gray-600">
      <input name="consent" type="checkbox" value="yes" class="mt-1 h-4 w-4 rounded border-gray-300" required />
      <span>I agree to save these details for solar quote follow-up and understand estimates are educational only.</span>
    </label>

    <button type="submit" class="focus-ring rounded-xl bg-bright-orange px-6 py-3 font-bold text-white shadow-lg hover:bg-orange-600" data-lead-submit>
      Save Quote Follow-Up
    </button>
    <p class="text-sm font-bold" data-lead-status aria-live="polite"></p>
  </form>

  <div class="mt-5">
    <DisclosureNote label="Privacy" text={disclosureSettings.leadCaptureDisclaimer} />
  </div>
</section>

<script>
  document.querySelectorAll("[data-lead-form]").forEach((wrapper) => {
    const form = wrapper.querySelector("[data-lead-form-fields]");
    const status = wrapper.querySelector("[data-lead-status]");
    const submit = wrapper.querySelector("[data-lead-submit]");
    const endpoint = wrapper.getAttribute("data-endpoint") || "";

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const fields = Object.fromEntries(new FormData(form).entries());
      const payload = {
        category: "quote_follow_up",
        type: "quote_follow_up",
        fields,
        contact: {
          name: fields.name,
          email: fields.email,
          phone: fields.phone,
          zip: fields.zip,
        },
        pageSlug: fields.pageSlug,
        placementId: fields.placementId,
        source: fields.source,
        metadata: {
          currentUrl: window.location.href,
          referrer: document.referrer,
          submittedAt: new Date().toISOString(),
        },
      };

      if (status) {
        status.className = "text-sm font-bold text-gray-500";
        status.textContent = "Submitting quote follow-up...";
      }
      if (submit) submit.setAttribute("disabled", "true");

      try {
        const response = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          const error = await response.json().catch(() => ({}));
          throw new Error(error.error || `Lead endpoint returned ${response.status}`);
        }

        if (status) {
          status.className = "text-sm font-bold text-soft-green";
          status.textContent = "Quote follow-up saved for admin review.";
        }
        form.reset();
      } catch (error) {
        if (status) {
          status.className = "text-sm font-bold text-bright-orange";
          status.textContent =
            error instanceof Error && error.message === "database_unconfigured"
              ? "Database is not connected yet. Please try again after setup is complete."
              : "Submission failed. Please try again in a moment.";
        }
      } finally {
        if (submit) submit.removeAttribute("disabled");
      }
    });
  });
</script>
