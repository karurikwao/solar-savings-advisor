---
import AdSlot from "@/components/AdSlot.astro";
import AffiliateOfferCard from "@/components/AffiliateOfferCard.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CTAButton from "@/components/CTAButton.astro";
import DisclosureNote from "@/components/DisclosureNote.astro";
import FAQ from "@/components/FAQ.astro";
import Icon from "@/components/Icon.astro";
import InternalLinks from "@/components/InternalLinks.astro";
import TrustBar from "@/components/TrustBar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { isPublished, questions, siteSettings } from "@/lib/content";
import { articleSchema } from "@/lib/schema";

export function getStaticPaths() {
  return questions.filter(isPublished).map((page) => ({ params: { slug: page.path }, props: { page } }));
}

const { page } = Astro.props;
const related = page.relatedQuestions
  .map((id) => questions.find((question) => question.id === id))
  .filter(Boolean);
const pagePath = `/questions/${page.path}/`;
const schema = articleSchema({
  siteName: siteSettings.siteName,
  siteUrl: siteSettings.siteUrl,
  path: pagePath,
  title: page.title,
  description: page.description,
  lastUpdated: page.lastUpdated,
  reviewedBy: page.reviewedBy,
  sources: page.sources,
});
---

<BaseLayout title={page.title} description={page.description} canonicalPath={pagePath} robots={page.noindex ? "noindex,nofollow" : undefined} schema={schema}>
  <section class="bg-deep-navy py-12 text-white">
    <div class="container-wide">
      <Breadcrumbs items={[{ label: "Questions", href: "/questions/" }, { label: page.title }]} />
      <p class="text-xs font-black uppercase tracking-wider text-solar-yellow">{page.category}</p>
      <h1 class="mt-3 text-4xl font-black md:text-5xl">{page.title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-gray-300">{page.description}</p>
    </div>
  </section>

  <section class="container-wide grid gap-8 py-12 lg:grid-cols-[minmax(0,1fr)_340px]">
    <article>
      <div class="surface-card border-soft-green/20 p-6">
        <p class="text-sm font-bold uppercase tracking-wider text-soft-green">Quick answer</p>
        <p class="mt-3 text-xl font-bold leading-relaxed text-deep-navy">{page.quickAnswer}</p>
      </div>
      <TrustBar lastUpdated={page.lastUpdated} reviewedBy={page.reviewedBy} factChecked={page.factChecked} sources={page.sources} />

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <section class="surface-card p-6">
          <div class="mb-4 flex items-center gap-2 text-soft-green">
            <Icon name="check" class="h-5 w-5" />
            <h2 class="text-xl font-black text-deep-navy">Best Fit</h2>
          </div>
          <ul class="space-y-3 text-sm leading-relaxed text-gray-600">
            {page.bestFor.map((item) => <li>{item}</li>)}
          </ul>
        </section>
        <section class="surface-card p-6">
          <div class="mb-4 flex items-center gap-2 text-bright-orange">
            <Icon name="x" class="h-5 w-5" />
            <h2 class="text-xl font-black text-deep-navy">Watch Outs</h2>
          </div>
          <ul class="space-y-3 text-sm leading-relaxed text-gray-600">
            {page.notBestFor.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      </div>

      <AdSlot placementId={page.ctaPlacementId} compact />

      <section class="my-8">
        <h2 class="text-2xl font-black text-deep-navy">{page.scenario.title}</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {page.scenario.details.map((detail) => (
            <div class="rounded-xl bg-yellow-50 p-4 text-sm font-bold text-deep-navy">{detail}</div>
          ))}
        </div>
      </section>

      <section class="my-8">
        <h2 class="text-2xl font-black text-deep-navy">Key Factors</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {page.factors.map((factor) => <li class="rounded-xl border border-gray-200 p-4 text-sm text-gray-700">{factor}</li>)}
        </ul>
      </section>

      <FAQ items={page.faqs} />
      <InternalLinks currentType="question" currentId={page.id} />

      {related.length > 0 && (
        <section class="my-10">
          <h2 class="mb-4 text-2xl font-black text-deep-navy">Related Questions</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {related.map((item) => item && (
              <a href={`/questions/${item.path}/`} class="rounded-xl border border-gray-200 p-4 font-bold text-deep-navy hover:border-bright-orange hover:bg-orange-50">
                {item.title}
              </a>
            ))}
          </div>
        </section>
      )}

      <DisclosureNote />
    </article>

    <aside class="space-y-6">
      <AffiliateOfferCard placementId={page.ctaPlacementId} />
      <AdSlot placementId="question-sidebar" compact />
      <div class="surface-card p-6">
        <h2 class="text-xl font-black text-deep-navy">Run the numbers</h2>
        <p class="mt-2 text-sm text-gray-600">Estimate your own monthly and long-term solar savings.</p>
        <div class="mt-5">
          <CTAButton href="/tools/solar-savings-calculator/" label="Open Calculator" placementId={page.ctaPlacementId} pageSlug={page.path} offerId="free-solar-report" partnerId="solar-savings-advisor" />
        </div>
      </div>
    </aside>
  </section>
</BaseLayout>
