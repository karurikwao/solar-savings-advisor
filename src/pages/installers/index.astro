---
import AdSlot from "@/components/AdSlot.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { installers, siteSettings } from "@/lib/content";

const directory = siteSettings.providerDirectory ?? {};
const title = directory.indexTitle ?? "Solar Installers by State";
const description = directory.indexDescription ?? "State-by-state solar installer directory and quote preparation guidance.";
---

<BaseLayout title={title} description={description}>
  <section class="bg-deep-navy py-12 text-white">
    <div class="container-wide">
      <h1 class="text-4xl font-black md:text-5xl">{title}</h1>
      <p class="mt-4 max-w-2xl text-lg text-gray-300">{description}</p>
    </div>
  </section>

  <section class="container-wide grid gap-8 py-12 lg:grid-cols-[2fr_1fr]">
    <div class="grid gap-5 sm:grid-cols-2">
      {installers.map((item) => (
        <a href={`/installers/${item.id}/`} class="surface-card p-6 transition hover:-translate-y-1 hover:shadow-xl">
          <h2 class="text-xl font-black text-deep-navy">{item.stateName}</h2>
          <p class="mt-2 text-sm leading-relaxed text-gray-600">{item.stateDescription}</p>
          <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
            <span class="rounded-xl bg-yellow-50 p-3 font-bold text-deep-navy">{item.avgCostPerWatt}</span>
            <span class="rounded-xl bg-green-50 p-3 font-bold text-deep-navy">{item.typicalPayback}</span>
          </div>
        </a>
      ))}
    </div>
    <AdSlot placementId="providers-index-hero" />
  </section>
</BaseLayout>
