---
import AdSlot from "@/components/AdSlot.astro";
import AffiliateOfferCard from "@/components/AffiliateOfferCard.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ComparisonTable from "@/components/ComparisonTable.astro";
import CTAButton from "@/components/CTAButton.astro";
import DisclosureNote from "@/components/DisclosureNote.astro";
import FAQ from "@/components/FAQ.astro";
import Icon from "@/components/Icon.astro";
import InternalLinks from "@/components/InternalLinks.astro";
import TrustBar from "@/components/TrustBar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { comparisons, isPublished, siteSettings } from "@/lib/content";
import { articleSchema } from "@/lib/schema";

export function getStaticPaths() {
  return comparisons.filter(isPublished).map((page) => ({ params: { slug: page.path }, props: { page } }));
}

const { page } = Astro.props;
const pagePath = `/compare/${page.path}/`;
const schema = articleSchema({
  siteName: siteSettings.siteName,
  siteUrl: siteSettings.siteUrl,
  path: pagePath,
  title: page.title,
  description: page.description,
  lastUpdated: page.lastUpdated,
  reviewedBy: page.reviewedBy,
  sources: page.sources,
});
---

<BaseLayout title={page.title} description={page.description} canonicalPath={pagePath} robots={page.noindex ? "noindex,nofollow" : undefined} schema={schema}>
  <section class="bg-deep-navy py-12 text-white">
    <div class="container-wide">
      <Breadcrumbs items={[{ label: "Compare", href: "/compare/" }, { label: page.title }]} />
      <h1 class="text-4xl font-black md:text-5xl">{page.title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-gray-300">{page.description}</p>
    </div>
  </section>

  <section class="container-wide grid gap-8 py-12 lg:grid-cols-[minmax(0,1fr)_340px]">
    <article>
      <div class="surface-card border-soft-green/20 p-6">
        <p class="text-sm font-bold uppercase tracking-wider text-soft-green">Bottom line</p>
        <p class="mt-3 text-xl font-bold leading-relaxed text-deep-navy">{page.winnerSummary}</p>
      </div>
      <TrustBar lastUpdated={page.lastUpdated} reviewedBy={page.reviewedBy} factChecked={page.factChecked} sources={page.sources} />

      <ComparisonTable titleA={page.optionA} titleB={page.optionB} rows={page.tableRows} />

      <div class="my-8 grid gap-6 md:grid-cols-2">
        <section class="surface-card p-6">
          <h2 class="text-xl font-black text-deep-navy">{page.optionA}</h2>
          <p class="mt-3 text-sm font-bold text-soft-green">{page.bestForA}</p>
          <h3 class="mt-5 text-sm font-black uppercase tracking-wider text-deep-navy">Pros</h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">{page.prosA.map((item) => <li>{item}</li>)}</ul>
          <h3 class="mt-5 text-sm font-black uppercase tracking-wider text-deep-navy">Cons</h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">{page.consA.map((item) => <li>{item}</li>)}</ul>
        </section>
        <section class="surface-card p-6">
          <h2 class="text-xl font-black text-deep-navy">{page.optionB}</h2>
          <p class="mt-3 text-sm font-bold text-soft-green">{page.bestForB}</p>
          <h3 class="mt-5 text-sm font-black uppercase tracking-wider text-deep-navy">Pros</h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">{page.prosB.map((item) => <li>{item}</li>)}</ul>
          <h3 class="mt-5 text-sm font-black uppercase tracking-wider text-deep-navy">Cons</h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">{page.consB.map((item) => <li>{item}</li>)}</ul>
        </section>
      </div>

      <section class="my-8 rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-solar-yellow/30 text-deep-navy">
            <Icon name="scale" class="h-5 w-5" />
          </span>
          <h2 class="text-2xl font-black text-deep-navy">Cost Considerations</h2>
        </div>
        <p class="mt-4 text-gray-600">{page.costConsiderations}</p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <CTAButton href="/installers/" label="Compare Installer Options" variant="green" placementId="compare-table" pageSlug={page.path} offerId="installer-comparison" partnerId="installer-partners" />
          <CTAButton href="/tools/solar-loan-calculator/" label="Estimate Loan Payment" variant="navy" placementId="compare-table" pageSlug={page.path} offerId="free-solar-report" partnerId="solar-savings-advisor" />
        </div>
      </section>

      <AdSlot placementId={page.monetizationPlacementId} compact />
      <FAQ items={page.faqs} />
      <InternalLinks currentType="comparison" currentId={page.id} />
      <DisclosureNote />
    </article>

    <aside class="space-y-6">
      <AffiliateOfferCard placementId={page.monetizationPlacementId} />
      <AdSlot placementId="compare-bottom" compact />
    </aside>
  </section>
</BaseLayout>
