---
import { siteSettings } from "@/lib/content";
import "@/styles/global.css";

const colors = siteSettings.colors;
const brandVars = [
  `--brand-solar-yellow:${colors.solarYellow}`,
  `--brand-deep-navy:${colors.deepNavy}`,
  `--brand-bright-orange:${colors.brightOrange}`,
  `--brand-soft-green:${colors.softGreen}`,
  `--brand-light-gray:${colors.lightGray}`,
].join(";");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Admin Dashboard | {siteSettings.siteName}</title>
  </head>
  <body class="min-h-screen bg-light-gray text-deep-navy" style={brandVars}>
    <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
      <header class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-xs font-black uppercase tracking-wider text-bright-orange">Admin</p>
          <h1 class="text-3xl font-black">Solar Savings Dashboard</h1>
        </div>
        <nav class="flex flex-wrap gap-2 text-sm font-bold">
          <a class="rounded-lg border border-gray-200 bg-white px-4 py-2 hover:border-bright-orange" href="/">Public Site</a>
          <a class="rounded-lg border border-gray-200 bg-white px-4 py-2 hover:border-bright-orange" href="/admin/">Admin Home</a>
        </nav>
      </header>

      <section class="surface-card p-5" data-auth-view>
        <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
          <form class="grid gap-3" data-login-form>
            <div>
              <p class="text-xs font-black uppercase tracking-wider text-gray-500">Sign In</p>
              <h2 class="text-2xl font-black">Admin access</h2>
            </div>
            <label class="text-sm font-bold">
              Email
              <input class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-login-email type="email" autocomplete="username" />
            </label>
            <label class="text-sm font-bold">
              Password
              <input class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-login-password type="password" autocomplete="current-password" />
            </label>
            <button class="rounded-xl bg-deep-navy px-5 py-3 font-bold text-white hover:bg-slate-800" type="submit">Sign In</button>
          </form>

          <div class="grid gap-4">
            <form class="grid gap-3 rounded-xl border border-gray-200 bg-white p-4" data-reset-request-form>
              <div>
                <p class="text-xs font-black uppercase tracking-wider text-gray-500">Lost Password</p>
                <h2 class="text-xl font-black">Email a reset link</h2>
              </div>
              <label class="text-sm font-bold">
                Admin Email
                <input class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-reset-email type="email" autocomplete="email" />
              </label>
              <button class="rounded-xl border border-gray-200 bg-white px-5 py-3 font-bold hover:border-bright-orange" type="submit">Send Reset Link</button>
            </form>

            <form class="grid gap-3 rounded-xl border border-gray-200 bg-white p-4" data-reset-form hidden>
              <div>
                <p class="text-xs font-black uppercase tracking-wider text-gray-500">Reset Password</p>
                <h2 class="text-xl font-black">Set a new password</h2>
              </div>
              <label class="text-sm font-bold">
                New Password
                <input class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-new-password type="password" autocomplete="new-password" />
              </label>
              <button class="rounded-xl bg-bright-orange px-5 py-3 font-bold text-white hover:bg-orange-600" type="submit">Update Password</button>
            </form>
          </div>
        </div>
        <p class="mt-4 text-sm font-bold text-gray-500" data-auth-status aria-live="polite">Checking admin session...</p>
      </section>

      <section data-dashboard hidden>
        <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="text-sm font-bold text-gray-500" data-user-label></p>
            <div class="mt-3 flex flex-wrap gap-2" role="tablist" aria-label="Admin dashboard sections">
              <button class="rounded-xl bg-deep-navy px-5 py-3 font-bold text-white" data-tab="leads" type="button">Leads</button>
              <button class="rounded-xl border border-gray-200 bg-white px-5 py-3 font-bold hover:border-bright-orange" data-tab="ads" type="button">Ads</button>
              <button class="rounded-xl border border-gray-200 bg-white px-5 py-3 font-bold hover:border-bright-orange" data-tab="account" type="button">Account</button>
            </div>
          </div>
          <button class="rounded-xl border border-gray-200 bg-white px-5 py-3 font-bold hover:border-bright-orange" data-sign-out type="button">Sign Out</button>
        </div>

        <div data-panel="leads">
          <section class="grid gap-3 md:grid-cols-4" data-summary></section>

          <section class="surface-card mt-6 p-5">
            <div class="grid gap-3 md:grid-cols-[1fr_1fr_auto_auto] md:items-end">
              <label class="text-sm font-bold">
                Category
                <select class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-category>
                  <option value="">All categories</option>
                  <option value="quote_follow_up">Quote follow-up</option>
                  <option value="contact">Contact</option>
                  <option value="solar_report">Solar reports</option>
                  <option value="calculator">Calculator runs</option>
                  <option value="profile">Profiles</option>
                  <option value="other">Other</option>
                </select>
              </label>
              <label class="text-sm font-bold">
                Status
                <select class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-filter-status>
                  <option value="">All statuses</option>
                  <option value="new">New</option>
                  <option value="reviewing">Reviewing</option>
                  <option value="contacted">Contacted</option>
                  <option value="qualified">Qualified</option>
                  <option value="closed">Closed</option>
                  <option value="spam">Spam</option>
                </select>
              </label>
              <button class="rounded-xl bg-bright-orange px-5 py-3 font-bold text-white hover:bg-orange-600" data-refresh type="button">Refresh</button>
              <button class="rounded-xl border border-gray-200 bg-white px-5 py-3 font-bold hover:border-bright-orange" data-export type="button">Export CSV</button>
            </div>
            <p class="mt-3 text-sm font-bold text-gray-500" data-leads-status aria-live="polite"></p>
          </section>

          <section class="surface-card mt-6 overflow-hidden">
            <div class="overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="border-b border-gray-100 bg-white text-xs uppercase tracking-wider text-gray-500">
                  <tr>
                    <th class="px-4 py-3">Created</th>
                    <th class="px-4 py-3">Category</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Contact</th>
                    <th class="px-4 py-3">ZIP</th>
                    <th class="px-4 py-3">Source</th>
                    <th class="px-4 py-3">Details</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white" data-rows>
                  <tr>
                    <td class="px-4 py-8 text-center text-gray-500" colspan="7">No submissions loaded.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>
        </div>

        <div data-panel="ads" hidden>
          <section class="surface-card p-5">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="text-xs font-black uppercase tracking-wider text-gray-500">Ad Controls</p>
                <h2 class="text-2xl font-black">Placement snippets</h2>
              </div>
              <button class="rounded-xl bg-bright-orange px-5 py-3 font-bold text-white hover:bg-orange-600" data-refresh-ads type="button">Refresh Ads</button>
            </div>
            <p class="mt-3 text-sm font-bold text-gray-500" data-ads-status aria-live="polite"></p>
          </section>
          <section class="mt-6 grid gap-4" data-ads-list></section>
        </div>

        <div data-panel="account" hidden>
          <section class="surface-card p-5">
            <p class="text-xs font-black uppercase tracking-wider text-gray-500">Account</p>
            <h2 class="text-2xl font-black">Signed-in admin</h2>
            <dl class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
              <div class="rounded-xl border border-gray-200 bg-white p-4">
                <dt class="font-black uppercase tracking-wider text-gray-500">Email</dt>
                <dd class="mt-1 font-bold" data-account-email></dd>
              </div>
              <div class="rounded-xl border border-gray-200 bg-white p-4">
                <dt class="font-black uppercase tracking-wider text-gray-500">Role</dt>
                <dd class="mt-1 font-bold" data-account-role></dd>
              </div>
            </dl>
          </section>
        </div>
      </section>
    </main>

    <script>
      const categoryLabels = {
        quote_follow_up: "Quote follow-up",
        contact: "Contact",
        solar_report: "Solar report",
        calculator: "Calculator",
        profile: "Profile",
        other: "Other",
      };
      const statusLabels = {
        new: "New",
        reviewing: "Reviewing",
        contacted: "Contacted",
        qualified: "Qualified",
        closed: "Closed",
        spam: "Spam",
      };
      const state = { user: null, resetToken: new URLSearchParams(location.search).get("reset") || "" };
      const els = {
        authView: document.querySelector("[data-auth-view]"),
        dashboard: document.querySelector("[data-dashboard]"),
        authStatus: document.querySelector("[data-auth-status]"),
        loginForm: document.querySelector("[data-login-form]"),
        loginEmail: document.querySelector("[data-login-email]"),
        loginPassword: document.querySelector("[data-login-password]"),
        resetRequestForm: document.querySelector("[data-reset-request-form]"),
        resetEmail: document.querySelector("[data-reset-email]"),
        resetForm: document.querySelector("[data-reset-form]"),
        newPassword: document.querySelector("[data-new-password]"),
        userLabel: document.querySelector("[data-user-label]"),
        signOut: document.querySelector("[data-sign-out]"),
        tabs: document.querySelectorAll("[data-tab]"),
        panels: document.querySelectorAll("[data-panel]"),
        summary: document.querySelector("[data-summary]"),
        category: document.querySelector("[data-category]"),
        filterStatus: document.querySelector("[data-filter-status]"),
        refresh: document.querySelector("[data-refresh]"),
        export: document.querySelector("[data-export]"),
        rows: document.querySelector("[data-rows]"),
        leadsStatus: document.querySelector("[data-leads-status]"),
        adsStatus: document.querySelector("[data-ads-status]"),
        refreshAds: document.querySelector("[data-refresh-ads]"),
        adsList: document.querySelector("[data-ads-list]"),
        accountEmail: document.querySelector("[data-account-email]"),
        accountRole: document.querySelector("[data-account-role]"),
      };

      const escapeHtml = (value) =>
        String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");

      const setStatus = (element, message, mode = "neutral") => {
        if (!element) return;
        const color = mode === "ok" ? "text-soft-green" : mode === "error" ? "text-bright-orange" : "text-gray-500";
        element.className = `mt-3 text-sm font-bold ${color}`;
        element.textContent = message;
      };

      const apiJson = async (url, options = {}) => {
        const response = await fetch(url, {
          credentials: "same-origin",
          ...options,
          headers: {
            ...(options.headers || {}),
            ...(options.body && !(options.body instanceof FormData) ? { "Content-Type": "application/json" } : {}),
          },
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.error || `request_${response.status}`);
        return data;
      };

      const showAuth = (message = "Sign in to continue.", mode = "neutral") => {
        if (els.authView) els.authView.hidden = false;
        if (els.dashboard) els.dashboard.hidden = true;
        if (els.resetForm) els.resetForm.hidden = !state.resetToken;
        setStatus(els.authStatus, message, mode);
      };

      const showDashboard = (user) => {
        state.user = user;
        if (els.authView) els.authView.hidden = true;
        if (els.dashboard) els.dashboard.hidden = false;
        if (els.userLabel) els.userLabel.textContent = `Signed in as ${user.email}`;
        if (els.accountEmail) els.accountEmail.textContent = user.email;
        if (els.accountRole) els.accountRole.textContent = user.role || "admin";
        switchTab("leads");
        loadRows();
      };

      const switchTab = (tab) => {
        els.tabs.forEach((button) => {
          const selected = button.getAttribute("data-tab") === tab;
          button.className = selected
            ? "rounded-xl bg-deep-navy px-5 py-3 font-bold text-white"
            : "rounded-xl border border-gray-200 bg-white px-5 py-3 font-bold hover:border-bright-orange";
        });
        els.panels.forEach((panel) => {
          panel.hidden = panel.getAttribute("data-panel") !== tab;
        });
        if (tab === "ads") loadAds();
      };

      const checkSession = async () => {
        try {
          const data = await apiJson("/api/admin/auth/session");
          showDashboard(data.user);
        } catch {
          showAuth(state.resetToken ? "Enter a new password to complete reset." : "Sign in to continue.");
        }
      };

      const formatDate = (value) => {
        if (!value) return "";
        return new Intl.DateTimeFormat(undefined, {
          month: "short",
          day: "numeric",
          hour: "numeric",
          minute: "2-digit",
        }).format(new Date(value));
      };

      const compactJson = (value) => {
        if (!value || typeof value !== "object") return "";
        return JSON.stringify(value, null, 2);
      };

      const queryParams = () => {
        const params = new URLSearchParams();
        if (els.category?.value) params.set("category", els.category.value);
        if (els.filterStatus?.value) params.set("status", els.filterStatus.value);
        params.set("limit", "250");
        return params;
      };

      const renderSummary = (counts) => {
        const byCategory = counts.reduce((acc, item) => {
          acc[item.category] = (acc[item.category] || 0) + item.count;
          return acc;
        }, {});
        const cards = ["quote_follow_up", "solar_report", "calculator", "contact"].map((category) => `
          <article class="surface-card p-4">
            <p class="text-xs font-black uppercase tracking-wider text-gray-500">${escapeHtml(categoryLabels[category])}</p>
            <p class="mt-2 text-3xl font-black">${Number(byCategory[category] || 0).toLocaleString()}</p>
          </article>
        `);
        if (els.summary) els.summary.innerHTML = cards.join("");
      };

      const renderRows = (rows) => {
        if (!els.rows) return;
        if (!rows.length) {
          els.rows.innerHTML = `<tr><td class="px-4 py-8 text-center text-gray-500" colspan="7">No matching submissions.</td></tr>`;
          return;
        }

        els.rows.innerHTML = rows.map((row) => {
          const contact = [row.contactName, row.contactEmail, row.contactPhone].filter(Boolean).map(escapeHtml).join("<br>");
          const source = [row.pageSlug, row.placementId, row.interest].filter(Boolean).map(escapeHtml).join("<br>");
          return `
            <tr data-row="${escapeHtml(row.id)}" class="align-top">
              <td class="whitespace-nowrap px-4 py-4 font-bold">${escapeHtml(formatDate(row.createdAt))}</td>
              <td class="px-4 py-4">${escapeHtml(categoryLabels[row.category] || row.category)}</td>
              <td class="px-4 py-4">
                <select class="w-36 rounded-lg border border-gray-200 px-3 py-2" data-row-status>
                  ${Object.entries(statusLabels).map(([value, label]) => `<option value="${value}"${row.status === value ? " selected" : ""}>${label}</option>`).join("")}
                </select>
              </td>
              <td class="px-4 py-4">${contact || "<span class=\"text-gray-400\">No contact</span>"}</td>
              <td class="px-4 py-4">${escapeHtml(row.zip)}</td>
              <td class="px-4 py-4 text-gray-600">${source}</td>
              <td class="min-w-80 px-4 py-4">
                <details class="rounded-lg border border-gray-200 bg-light-gray p-3">
                  <summary class="cursor-pointer font-bold">View details</summary>
                  <textarea class="mt-3 h-20 w-full rounded-lg border border-gray-200 px-3 py-2 text-sm" data-row-notes placeholder="Admin notes">${escapeHtml(row.adminNotes)}</textarea>
                  <button class="mt-2 rounded-lg bg-deep-navy px-4 py-2 text-sm font-bold text-white" data-save-row type="button">Save</button>
                  <pre class="mt-3 max-h-96 overflow-auto rounded-lg bg-white p-3 text-xs">${escapeHtml(compactJson({ resultSummary: row.resultSummary, payload: row.payload }))}</pre>
                </details>
              </td>
            </tr>
          `;
        }).join("");
      };

      const loadRows = async () => {
        try {
          setStatus(els.leadsStatus, "Loading submissions...");
          const data = await apiJson(`/api/admin/submissions?${queryParams().toString()}`);
          renderSummary(data.counts || []);
          renderRows(data.rows || []);
          setStatus(els.leadsStatus, `Loaded ${(data.rows || []).length.toLocaleString()} submissions.`, "ok");
        } catch (error) {
          setStatus(els.leadsStatus, error.message === "database_unconfigured" ? "DATABASE_URL is not configured." : "Could not load submissions.", "error");
        }
      };

      const renderAds = (rows) => {
        if (!els.adsList) return;
        if (!rows.length) {
          els.adsList.innerHTML = `<div class="surface-card p-5 text-sm font-bold text-gray-500">No placements found.</div>`;
          return;
        }

        els.adsList.innerHTML = rows.map((row) => `
          <article class="surface-card p-5" data-ad-row="${escapeHtml(row.placementId)}">
            <div class="grid gap-4 lg:grid-cols-[1fr_auto] lg:items-start">
              <div>
                <p class="text-xs font-black uppercase tracking-wider text-gray-500">${escapeHtml(row.templateArea)}</p>
                <h3 class="text-xl font-black">${escapeHtml(row.label)}</h3>
                <p class="mt-1 text-sm font-bold text-gray-500">${escapeHtml(row.placementId)}</p>
              </div>
              <label class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm font-bold">
                <input data-ad-enabled type="checkbox"${row.enabled ? " checked" : ""} />
                Enabled
              </label>
            </div>
            <div class="mt-4 grid gap-3 lg:grid-cols-[1fr_1fr]">
              <label class="text-sm font-bold">
                Label
                <input class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-ad-label value="${escapeHtml(row.label)}" />
              </label>
              <label class="text-sm font-bold">
                Template Area
                <input class="mt-1.5 w-full rounded-xl border border-gray-200 px-4 py-3" data-ad-template value="${escapeHtml(row.templateArea)}" />
              </label>
            </div>
            <label class="mt-4 block text-sm font-bold">
              Custom Ad Snippet
              <textarea class="mt-1.5 h-40 w-full rounded-xl border border-gray-200 px-4 py-3 font-mono text-xs" data-ad-snippet spellcheck="false" placeholder="Ad network HTML or script snippet">${escapeHtml(row.snippet)}</textarea>
            </label>
            <label class="mt-4 block text-sm font-bold">
              Notes
              <textarea class="mt-1.5 h-20 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm" data-ad-notes>${escapeHtml(row.notes)}</textarea>
            </label>
            <button class="mt-4 rounded-xl bg-deep-navy px-5 py-3 font-bold text-white hover:bg-slate-800" data-save-ad type="button">Save Placement</button>
          </article>
        `).join("");
      };

      const loadAds = async () => {
        try {
          setStatus(els.adsStatus, "Loading ad placements...");
          const data = await apiJson("/api/admin/ad-placements");
          renderAds(data.rows || []);
          setStatus(els.adsStatus, `Loaded ${(data.rows || []).length.toLocaleString()} placements.`, "ok");
        } catch {
          setStatus(els.adsStatus, "Could not load ad placements.", "error");
        }
      };

      els.loginForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        try {
          setStatus(els.authStatus, "Signing in...");
          const data = await apiJson("/api/admin/auth/login", {
            method: "POST",
            body: JSON.stringify({ email: els.loginEmail?.value || "", password: els.loginPassword?.value || "" }),
          });
          showDashboard(data.user);
        } catch {
          showAuth("Email or password was not accepted.", "error");
        }
      });

      els.resetRequestForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        try {
          await apiJson("/api/admin/auth/request-reset", {
            method: "POST",
            body: JSON.stringify({ email: els.resetEmail?.value || "" }),
          });
          showAuth("If that email is an admin, a reset link was sent.", "ok");
        } catch {
          showAuth("Could not request a reset link.", "error");
        }
      });

      els.resetForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        try {
          const data = await apiJson("/api/admin/auth/reset-password", {
            method: "POST",
            body: JSON.stringify({ token: state.resetToken, password: els.newPassword?.value || "" }),
          });
          history.replaceState({}, "", "/admin/leads/");
          showDashboard(data.user);
        } catch (error) {
          showAuth(error.message === "password_too_short" ? "Use at least 10 characters." : "Reset link is invalid or expired.", "error");
        }
      });

      els.signOut?.addEventListener("click", async () => {
        await apiJson("/api/admin/auth/logout", { method: "POST" }).catch(() => {});
        state.user = null;
        showAuth("Signed out.", "ok");
      });
      els.tabs.forEach((button) => button.addEventListener("click", () => switchTab(button.getAttribute("data-tab") || "leads")));
      els.refresh?.addEventListener("click", loadRows);
      els.category?.addEventListener("change", loadRows);
      els.filterStatus?.addEventListener("change", loadRows);
      els.refreshAds?.addEventListener("click", loadAds);
      els.export?.addEventListener("click", async () => {
        try {
          setStatus(els.leadsStatus, "Preparing CSV export...");
          const response = await fetch(`/api/admin/submissions.csv?${queryParams().toString()}`, { credentials: "same-origin" });
          if (!response.ok) throw new Error("export_failed");
          const blob = await response.blob();
          const url = URL.createObjectURL(blob);
          const link = document.createElement("a");
          link.href = url;
          link.download = `solar-submissions-${new Date().toISOString().slice(0, 10)}.csv`;
          document.body.append(link);
          link.click();
          link.remove();
          URL.revokeObjectURL(url);
          setStatus(els.leadsStatus, "CSV export downloaded.", "ok");
        } catch {
          setStatus(els.leadsStatus, "Could not export CSV.", "error");
        }
      });
      els.rows?.addEventListener("click", async (event) => {
        const button = event.target.closest("[data-save-row]");
        if (!button) return;
        const row = button.closest("[data-row]");
        const id = row?.getAttribute("data-row");
        if (!id) return;
        try {
          await apiJson(`/api/admin/submissions/${encodeURIComponent(id)}`, {
            method: "PATCH",
            body: JSON.stringify({
              status: row.querySelector("[data-row-status]")?.value || "new",
              adminNotes: row.querySelector("[data-row-notes]")?.value || "",
            }),
          });
          setStatus(els.leadsStatus, "Submission updated.", "ok");
        } catch {
          setStatus(els.leadsStatus, "Could not update submission.", "error");
        }
      });
      els.adsList?.addEventListener("click", async (event) => {
        const button = event.target.closest("[data-save-ad]");
        if (!button) return;
        const row = button.closest("[data-ad-row]");
        const placementId = row?.getAttribute("data-ad-row");
        if (!placementId) return;
        try {
          await apiJson(`/api/admin/ad-placements/${encodeURIComponent(placementId)}`, {
            method: "PUT",
            body: JSON.stringify({
              enabled: Boolean(row.querySelector("[data-ad-enabled]")?.checked),
              label: row.querySelector("[data-ad-label]")?.value || placementId,
              templateArea: row.querySelector("[data-ad-template]")?.value || "",
              snippet: row.querySelector("[data-ad-snippet]")?.value || "",
              notes: row.querySelector("[data-ad-notes]")?.value || "",
            }),
          });
          setStatus(els.adsStatus, "Ad placement saved.", "ok");
        } catch {
          setStatus(els.adsStatus, "Could not save ad placement.", "error");
        }
      });

      checkSession();
    </script>
  </body>
</html>
