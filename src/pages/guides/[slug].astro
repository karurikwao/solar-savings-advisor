---
import AdSlot from "@/components/AdSlot.astro";
import AffiliateOfferCard from "@/components/AffiliateOfferCard.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import DisclosureNote from "@/components/DisclosureNote.astro";
import FAQ from "@/components/FAQ.astro";
import InternalLinks from "@/components/InternalLinks.astro";
import TrustBar from "@/components/TrustBar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { guides, isPublished, siteSettings } from "@/lib/content";
import { articleSchema } from "@/lib/schema";

export function getStaticPaths() {
  return guides.filter(isPublished).map((page) => ({ params: { slug: page.path }, props: { page } }));
}

const { page } = Astro.props;
const pagePath = `/guides/${page.path}/`;
const schema = articleSchema({
  siteName: siteSettings.siteName,
  siteUrl: siteSettings.siteUrl,
  path: pagePath,
  title: page.title,
  description: page.description,
  type: "Guide",
  lastUpdated: page.lastUpdated,
  reviewedBy: page.reviewedBy,
  sources: page.sources,
});
---

<BaseLayout title={page.title} description={page.description} canonicalPath={pagePath} robots={page.noindex ? "noindex,nofollow" : undefined} schema={schema}>
  <section class="bg-deep-navy py-12 text-white">
    <div class="container-wide">
      <Breadcrumbs items={[{ label: "Guides", href: "/guides/" }, { label: page.title }]} />
      <h1 class="text-4xl font-black md:text-5xl">{page.title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-gray-300">{page.description}</p>
    </div>
  </section>

  <section class="container-wide grid gap-8 py-12 lg:grid-cols-[minmax(0,1fr)_340px]">
    <article>
      <AdSlot placementId={page.bannerPlacementId} compact />
      <TrustBar lastUpdated={page.lastUpdated} reviewedBy={page.reviewedBy} factChecked={page.factChecked} sources={page.sources} />

      <section class="my-8 surface-card p-6">
        <h2 class="text-2xl font-black text-deep-navy">Key Takeaways</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {page.keyTakeaways.map((takeaway) => <li class="rounded-xl bg-green-50 p-4 text-sm font-bold text-deep-navy">{takeaway}</li>)}
        </ul>
      </section>

      <div class="prose-solar">
        {page.sections.map((section) => (
          <section class="my-8">
            <h2 class="text-2xl font-black text-deep-navy">{section.title}</h2>
            <p class="mt-3">{section.content}</p>
          </section>
        ))}
      </div>

      <FAQ items={page.faqs} />
      <InternalLinks currentType="guide" currentId={page.id} />
      <DisclosureNote />
    </article>

    <aside class="space-y-6">
      <AffiliateOfferCard placementId={page.bannerPlacementId} />
      <AdSlot placementId="guide-bottom" compact />
    </aside>
  </section>
</BaseLayout>
